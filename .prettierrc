{
  "trailingComma": "none",
  "tabWidth": 4,
  "semi": true,
  "singleQuote": true,
  "printWidth": 100,
  "plugins": ["@prettier/plugin-xml"],
  "overrides": [
    {
      "files": "*.{cmp,page,component}",
      "options": { "parser": "html" }
    },
    {
      "files": "*.yml",
      "options": { "tabWidth": 2 }
    }
  ]
}