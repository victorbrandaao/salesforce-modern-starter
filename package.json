{
    "name": "salesforce-modern-starter",
    "private": true,
    "version": "1.0.0",
    "description": "Professional Salesforce DX Starter Template",
    "scripts": {
        "prepare": "husky install",
        "lint": "eslint . --ext .js",
        "prettier": "prettier --write \"**/*.{cls,cmp,component,css,html,js,json,md,page,pb,apex,trigger,xml,yaml,yml}\"",
        "prettier:check": "prettier --check \"**/*.{cls,cmp,component,css,html,js,json,md,page,pb,apex,trigger,xml,yaml,yml}\"",
        "test": "npm run test:apex",
        "test:apex": "sf project deploy validate --source-dir force-app --test-level RunSpecifiedTests --tests AccountServiceTest --tests AccountTriggerHandlerTest --wait 10",
        "validate": "npm run lint && npm run prettier:check && npm test",
        "env:setup": "node scripts/setup.js",
        "release": "commit-and-tag-version"
    },
    "lint-staged": {
        "**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@prettier/plugin-xml": "^3.4.2",
        "commit-and-tag-version": "^12.7.1",
        "eslint": "^8.57.0",
        "globals": "^15.0.0",
        "husky": "^9.1.0",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "prettier-plugin-apex": "^2.2.6"
    }
}
